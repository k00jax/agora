# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database (Supabase Postgres direct connection)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Shared API Keys (your pool — used when user has no personal key)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
GROK_API_KEY=xai-...
DEEPSEEK_API_KEY=sk-...

# Encryption key for per-user API keys at rest (32 byte hex)
DB_ENCRYPTION_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# TTS service (deployed separately — edge-tts Python microservice)
TTS_SERVICE_URL=http://localhost:8080

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
